# Deploy SSH Configuration (GitHub Actions)
# Store all values below in GitHub Secrets/Variables, not in .env files
# See README.md for setup instructions

# Required: GitHub Secrets
DEPLOY_SSH_HOST=CHANGE_ME_SSH_HOST
DEPLOY_SSH_USER=CHANGE_ME_SSH_USER
DEPLOY_SSH_PRIVATE_KEY=CHANGE_ME_PRIVATE_KEY_OPENSSH
DEPLOY_SSH_KNOWN_HOSTS=CHANGE_ME_SSH_KNOWN_HOSTS

# Required: GitHub Variables (or Secrets)
DEPLOY_SSH_PORT=22
DEPLOY_REMOTE_DIR=CHANGE_ME_REMOTE_DIR
DEPLOY_HEALTHCHECK_URL=CHANGE_ME_HEALTHCHECK_URL

# Optional
DEPLOY_DEBUG=false
